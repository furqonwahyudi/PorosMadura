# Environment Variables — Poros Madura Backend

# Server
NODE_ENV=development
PORT=3001

# Database PostgreSQL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/poros_madura?schema=public"

# JWT
JWT_SECRET=poros_madura_jwt_secret_change_this_in_production_2026
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=poros_madura_refresh_secret_change_this_in_production_2026
JWT_REFRESH_EXPIRES_IN=30d

# Admin default (akan dibuat saat seed)
ADMIN_EMAIL=admin@porosmadura.com
ADMIN_PASSWORD=Admin@PorosMadura2026

# Storage (local)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# CORS — izinkan frontend development
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Gemini API Key untuk AI News Generator
GEMINI_API_KEY="masukkan_api_key_gemini_anda_di_sini"

